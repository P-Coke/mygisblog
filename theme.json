{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1240px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        { "slug": "ink", "name": "GIS Ink", "color": "#09111f" },
        { "slug": "ocean", "name": "Ocean", "color": "#11263d" },
        { "slug": "water", "name": "Water", "color": "#1e4662" },
        { "slug": "grid", "name": "Grid", "color": "#8190a2" },
        { "slug": "mist", "name": "Mist", "color": "#cad3de" },
        { "slug": "accent", "name": "Accent", "color": "#9ad1ff" },
        { "slug": "paper", "name": "Paper", "color": "#f4f7fb" },
        { "slug": "white", "name": "White", "color": "#ffffff" }
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "\"Noto Serif SC\", \"Source Han Serif SC\", \"Songti SC\", serif",
          "name": "Noto Serif SC",
          "slug": "display"
        },
        {
          "fontFamily": "\"Noto Sans SC\", \"Source Han Sans SC\", \"Microsoft YaHei UI\", sans-serif",
          "name": "Noto Sans SC",
          "slug": "body"
        },
        {
          "fontFamily": "\"IBM Plex Mono\", monospace",
          "name": "IBM Plex Mono",
          "slug": "mono"
        }
      ],
      "fontSizes": [
        { "slug": "xs", "name": "XS", "size": "0.85rem" },
        { "slug": "sm", "name": "SM", "size": "1rem" },
        { "slug": "md", "name": "MD", "size": "1.2rem" },
        { "slug": "lg", "name": "LG", "size": "clamp(1.75rem, 2.6vw, 2.75rem)" },
        { "slug": "xl", "name": "XL", "size": "clamp(2.8rem, 6vw, 5.5rem)" }
      ]
    },
    "spacing": {
      "defaultSpacingSizes": false,
      "spacingSizes": [
        { "slug": "20", "size": "0.5rem", "name": "20" },
        { "slug": "30", "size": "0.875rem", "name": "30" },
        { "slug": "40", "size": "1.25rem", "name": "40" },
        { "slug": "50", "size": "2rem", "name": "50" },
        { "slug": "60", "size": "3.25rem", "name": "60" },
        { "slug": "70", "size": "5rem", "name": "70" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "#f4f7fb",
      "text": "#09111f"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--sm)",
      "lineHeight": "1.72"
    },
    "blocks": {
      "core/site-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontWeight": "600"
        }
      },
      "core/heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontWeight": "600",
          "lineHeight": "1.12"
        }
      },
      "core/button": {
        "border": {
          "radius": "999px"
        },
        "spacing": {
          "padding": {
            "top": "0.9rem",
            "bottom": "0.9rem",
            "left": "1.4rem",
            "right": "1.4rem"
          }
        }
      }
    }
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header",
      "title": "Header"
    },
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    }
  ]
}
